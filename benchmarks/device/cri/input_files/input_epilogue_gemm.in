#############################################################################
### Activation-fused epilogue GEMM benchmarks (CRI simulator)             ###
#############################################################################
#
# Sync from example 05_bmg_gemm_with_epilogues:
#   05_bmg_gemm_with_epilogue_relu
#   05_bmg_gemm_with_epilogue_silu
#   05_bmg_gemm_with_epilogue_gelu
#
# These compute D = Act(alpha * (A * B) + beta * C) on a BF16 RowMajor GEMM,
# using MainloopXeL1Staged + IntelXeGeneric epilogue, TileShape <256,256,32>.
#
# IMPORTANT: the generic benchmark verify() compares against a plain GEMM
# reference and does NOT apply the activation function. Verification is
# disabled under CUTLASS_TEST_FOR_CRI, so these cases are only meant for the
# CRI simulator path (here). Do NOT add them to the BMG/PVC CI input files,
# where verify() runs and would (correctly) report a mismatch.
#
# Compare against the upstream examples with matching problem sizes, e.g.:
#   ./examples/sycl/05_bmg_gemm_with_epilogues/05_bmg_gemm_with_epilogue_relu --m=1024 --n=1024 --k=1024
#   ./examples/sycl/05_bmg_gemm_with_epilogues/05_bmg_gemm_with_epilogue_silu --m=1024 --n=1024 --k=1024
#   ./examples/sycl/05_bmg_gemm_with_epilogues/05_bmg_gemm_with_epilogue_gelu --m=1024 --n=1024 --k=1024

# --- ReLU ---
#BmgGemmReLUBF16BF16FP32_RRR_TileShape_256_256_32 --bm_name=cri_gemm_relu --m=1024 --n=1024 --k=1024
BmgGemmReLUBF16BF16FP32_RRR_TileShape_256_256_32 --bm_name=cri_gemm_relu --m=512 --n=256 --k=1024
#BmgGemmReLUBF16BF16FP32_RRR_TileShape_256_256_32 --bm_name=cri_gemm_relu --m=512 --n=256 --k=2048
#BmgGemmReLUBF16BF16FP32_RRR_TileShape_256_256_32 --bm_name=cri_gemm_relu --m=512 --n=256 --k=4096

# --- SiLU ---
#BmgGemmSiLUBF16BF16FP32_RRR_TileShape_256_256_32 --bm_name=cri_gemm_silu --m=1024 --n=1024 --k=1024
BmgGemmSiLUBF16BF16FP32_RRR_TileShape_256_256_32 --bm_name=cri_gemm_silu --m=512 --n=256 --k=1024
#BmgGemmSiLUBF16BF16FP32_RRR_TileShape_256_256_32 --bm_name=cri_gemm_silu --m=512 --n=256 --k=2048
#BmgGemmSiLUBF16BF16FP32_RRR_TileShape_256_256_32 --bm_name=cri_gemm_silu --m=512 --n=256 --k=4096

# --- GELU ---
#BmgGemmGELUBF16BF16FP32_RRR_TileShape_256_256_32 --bm_name=cri_gemm_gelu --m=1024 --n=1024 --k=1024
BmgGemmGELUBF16BF16FP32_RRR_TileShape_256_256_32 --bm_name=cri_gemm_gelu --m=512 --n=256 --k=1024
#BmgGemmGELUBF16BF16FP32_RRR_TileShape_256_256_32 --bm_name=cri_gemm_gelu --m=512 --n=256 --k=2048
#BmgGemmGELUBF16BF16FP32_RRR_TileShape_256_256_32 --bm_name=cri_gemm_gelu --m=512 --n=256 --k=4096
